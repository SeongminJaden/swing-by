def fibonacci(n: int) -> list[int]:
    \"\"\"
    주어진 횟수(n)까지의 피보나치 수열을 계산하여 리스트로 반환합니다.
    반복문 방식을 사용하여 O(n) 시간 복잡도와 O(1) 공간 복잡도를 유지합니다.
    \"\"\"
    if n <= 0:
        return []
    if n == 1:
        return [0]
    
    # 초기 두 항
    a, b = 0, 1
    sequence = [a, b]
    
    # n-2번 반복 (이미 2개 항이 있으므로)
    for _ in range(2, n):
        next_fib = a + b
        sequence.append(next_fib)
        # 다음 순회를 위해 값 업데이트
        a = b
        b = next_fib
        
    return sequence

# --- 예제 실행 ---
if __name__ == "__main__":
    # 10번째 항까지 (총 10개 숫자) 출력
    N_TERMS = 10
    result = fibonacci(N_TERMS)
    print(f"--- 피보나치 수열 ({N_TERMS}개 항) ---")
    print(f"결과: {result}")

    # 테스트 케이스: 1개 항
    print(f"1개 항 테스트: {fibonacci(1)}")
    # 테스트 케이스: 2개 항
    print(f"2개 항 테스트: {fibonacci(2)}")
"""